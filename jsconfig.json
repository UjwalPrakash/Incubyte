{
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ESNext",
    "checkJs": false,
    "allowJs": true,
    "baseUrl": ".",
    "paths": {
      "@pages/*": ["src/pages/*"],
      "@fixtures/*": ["src/fixtures/*"],
      "@steps/*": ["src/steps/*"],
      "@config/*": ["config/*"]
    }
  },
  "include": [
    "src/**/*",
    "config/**/*",
    "playwright.config.js"
  ],
  "exclude": [
    "node_modules",
    ".features-gen"
  ]
}
